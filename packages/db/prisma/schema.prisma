generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Task {
  id        String     @id @default(cuid())
  title     String
  prompt    String
  workspaceId String?
  status    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  events    Event[]
  artifacts Artifact[]
  approvals Approval[]
  taskSource TaskSource?
  contextSnapshot ContextSnapshot?
  patchLifecycle PatchLifecycle?
  commandRuns CommandRun[]
  previewSessions PreviewSession[]
  auditEvents AuditEvent[]

  @@index([status])
  @@index([createdAt])
  @@index([workspaceId])
}

model ContextSnapshot {
  id            String   @id
  taskId        String   @unique
  selectedFiles String
  rejectedFiles String
  createdAt     DateTime
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model PatchLifecycle {
  id             String   @id
  taskId         String   @unique
  patchArtifactId String
  approvalId     String?
  status         String
  precheck       String
  applyResult    String?
  createdAt      DateTime
  updatedAt      DateTime
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model CommandRun {
  id             String   @id
  taskId         String
  approvalId     String?
  command        String
  status         String
  exitCode       Int?
  stdout         String?
  stderr         String?
  startedAt      DateTime?
  completedAt    DateTime?
  outputArtifactId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([taskId, status])
}

model Event {
  id        String   @id @default(cuid())
  taskId    String
  type      String
  agentRole String?
  message   String
  payload   String?
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([type])
}

model Artifact {
  id        String   @id @default(cuid())
  taskId    String
  kind      String
  title     String
  content   String
  metadata  String?
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, kind])
  @@index([createdAt])
}

model Approval {
  id        String    @id @default(cuid())
  taskId    String
  kind      String
  status    String
  payload   String
  createdAt DateTime  @default(now())
  decidedAt DateTime?
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, status])
  @@index([createdAt])
}

model Workspace {
  id              String          @id
  name            String
  rootPath        String          @unique
  status          String
  runnerMode      String
  runnerId        String?
  branch          String?
  lastHeartbeatAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  tasks           Task[]
  previewSessions PreviewSession[]
  runnerSessions  RunnerSession[]
  auditEvents     AuditEvent[]

  @@index([status])
  @@index([runnerId])
}

model RunnerSession {
  id              String   @id
  runnerId        String   @unique
  workspaceId     String
  workspaceRoot   String
  status          String
  protocolVersion String
  capabilities    String
  controlBaseUrl  String
  controlToken    String
  connectedAt     DateTime
  lastHeartbeatAt DateTime
  disconnectedAt  DateTime?
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([status])
}

model PreviewSession {
  id               String   @id
  taskId           String
  workspaceId      String
  status           String
  url              String
  port             Int
  command          String
  startedAt        DateTime
  stoppedAt        DateTime?
  lastHeartbeatAt  DateTime?
  failureMessage   String?
  task             Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([taskId])
  @@index([workspaceId, status])
  @@index([startedAt])
}

model TaskSource {
  id        String   @id
  taskId    String   @unique
  kind      String
  title     String
  content   String
  url       String?
  createdAt DateTime
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id          String    @id
  taskId      String?
  workspaceId String?
  source      String
  action      String
  message     String
  metadata    String?
  createdAt   DateTime
  task        Task?      @relation(fields: [taskId], references: [id], onDelete: SetNull)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([action])
}
